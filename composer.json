    "license": "MIT",
    "authors": [
        {
            "name": "Olivier Plathey",
            "email": "oliver@fpdf.org",
            "homepage": "http://fpdf.org/"
        }
    ],
    "require": {
        "php": ">=5.3.0"
    },
    "suggest": {
        "ext-gd": "*"
    },
    "autoload": {
        "classmap": [
            "fpdf/fpdf.php"
        ]
    }
}
